# Next.js does not load this file for `npm run dev`. Use `npm run dev:staging`
# (loads this file), or copy these vars into `.env.local` if you prefer `npm run dev`.

NEXT_PUBLIC_SANITY_PROJECT_ID="hoc4qxji" # Required - Same Sanity project ID used by production
NEXT_PUBLIC_SANITY_DATASET="staging-2026" # Required - Staging dataset for 2026 content updates
NEXT_PUBLIC_SANITY_API_VERSION="2024-10-28" # Optional - API version provided to the Sanity client
NEXT_PUBLIC_SANITY_STUDIO_URL="" # Optional, defaults to http://localhost:3333
# Required for /api/draft-mode/enable (Sanity Presentation). Without it, the enable route returns 401.
SANITY_API_READ_TOKEN="<paste your token here>" # Required - Token with read access to staging-2026
NEXT_PUBLIC_SITE_ENV="staging" # Optional - Helps distinguish staging deploys in logs/UI

# In Sanity → Project → API → CORS origins, add: https://staging-2026.virginiaopioidcostdata.org
# (Credentials allowed) so the browser can call the Sanity API from that host.

# Optional: comma-separated extra origins allowed to embed this app (CSP frame-ancestors), e.g. another Studio host.
# ADDITIONAL_FRAME_ANCESTORS=
